# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── eBay Market Price API ─────────────────────────────────
# Register at: https://developer.ebay.com — create an app, get Production keys
# App ID = Client ID, Cert ID = Client Secret
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id

# ── DVLA Vehicle Enquiry Service (VES) ───────────────────
# Instant API key — register at:
# https://developer-portal.driver-vehicle-licensing.agency.gov.uk/
# Returns: make, colour, fuel type, MOT expiry, tax status, engine size, year.
# (No MOT test history — use DVSA for that)
DVLA_API_KEY=your_dvla_api_key

# ── DVSA MOT History API ──────────────────────────────────
# Register at: https://documentation.history.mot.api.gov.uk/mot-history-api/register
# These credentials are emailed to you after DVSA approval.
DVSA_CLIENT_ID=your_dvsa_client_id
DVSA_CLIENT_SECRET=your_dvsa_client_secret
DVSA_API_KEY=your_dvsa_api_key
# Full token URL including tenantId — provided by DVSA in your credentials email:
DVSA_TOKEN_URL=https://login.microsoftonline.com/{tenantId}/oauth2/v2.0/token
DVSA_SCOPE=https://tapi.dvsa.gov.uk/.default
